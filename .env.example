# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram

# Required: Your Telegram bot token
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Optional: Group chat ID for logging/debugging
TELEGRAM_GROUP_CHAT_ID=

# Button URLs - Configure these for your welcome message buttons
# Group Rules button
GROUP_RULES_URL=https://example.com/rules

# Official Website button
WEBSITE_URL=https://example.com

# Join Channel button
CHANNEL_URL=https://t.me/examplechannel

# Contact Admin button - URL version
ADMIN_URL=https://t.me/exampleadmin

# Contact Admin button - Username (used as fallback if ADMIN_URL not provided)
ADMIN_USERNAME=exampleadmin

# Debug mode - set to 'true' to enable verbose logging
DEBUG=false
